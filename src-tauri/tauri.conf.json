{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "warden-desktop",
  "version": "2.0.0-beta",
  "identifier": "com.warden-desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Warden",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": false,
        "shadow": true,
        "backgroundColor": "#161616"
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset:; img-src 'self' blob: data: asset: tauri:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' http://127.0.0.1:8765 ipc: http://ipc.localhost asset:"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVDRDQyRjFBM0QxMzI5NzMKUldSektSTTlHaS9VN0lEVVl4V0ZqS1lMbndCRjJ3RmRxbHY3aVgzMTEyNWVON1BzV3BUSy9KSTEK",
      "endpoints": [
        "https://github.com/elev1e1nSure/warden-desktop/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico"],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/128x128.png",
        "installMode": "currentUser"
      }
    }
  }
}
